{
  "name": "preventivi-pittura-edile",
  "version": "1.0.0",
  "description": "Gestione Preventivi per Imprese di Pittura Edile - Standalone",
  "main": "main.js",
  "author": "Pittura Edile S.r.l.",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:nsis": "electron-builder --win nsis",
    "build:portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.pitturaedile.preventivi",
    "productName": "Preventivi Pittura Edile",
    "compression": "maximum",
    "removePackageScripts": true,
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "icon.ico",
      "frontend-build/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/preventivi-backend.exe",
        "to": "backend/preventivi-backend.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.ico",
      "publisherName": "Pittura Edile S.r.l.",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "allowElevation": true,
      "unicode": true,
      "include": "installer.nsh",
      "deleteAppDataOnUninstall": false,
      "menuCategory": "Pittura Edile",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Preventivi Pittura",
      "license": "LICENSE.txt",
      "runAfterFinish": true,
      "artifactName": "PreventiviPittura-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "PreventiviPittura-Standalone-${version}.${ext}"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
